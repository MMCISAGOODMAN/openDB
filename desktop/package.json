{
  "name": "opendb-desktop",
  "version": "0.2.0",
  "description": "openDB desktop client",
  "main": "main.js",
  "private": true,
  "author": "openDB",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --config electron-builder.yml",
    "dist:mac": "electron-builder --mac --config electron-builder.yml",
